{
  "name": "micro-frontend-saas-dashboard",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev":           "npm run dev:host",
    "dev:host":      "npm run dev --workspace=packages/host",
    "dev:dashboard": "npm run dev --workspace=packages/dashboard",
    "dev:analytics": "npm run dev --workspace=packages/analytics",
    "build":         "npm run build --workspaces --if-present",
    "type-check":    "npm run type-check --workspaces --if-present",
    "test":          "npm run test --workspaces --if-present",
    "lint":          "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm":  ">=9.0.0"
  }
}
